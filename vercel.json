{
  "buildCommand": "test -f data/usage.json && test -f data/usage.js && echo 'Serving prebuilt static dashboard bundle'",
  "outputDirectory": ".",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/data/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/(.*)",
      "headers": [{ "key": "X-Content-Type-Options", "value": "nosniff" }]
    }
  ]
}
