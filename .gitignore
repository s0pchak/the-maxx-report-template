# uv-managed virtualenv (the importer has no deps; this is just the pinned interpreter)
.venv/

# Your generated dashboard data lives here and is gitignored so it never gets
# committed by accident. The page falls back to the committed data/usage.sample.*
# files, and the updater force-adds these only when you explicitly publish.
data/usage.json
data/usage.js
.gstack/
